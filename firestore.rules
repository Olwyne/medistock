rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isMember(familyId) {
      return request.auth != null &&
        exists(/databases/$(database)/documents/families/$(familyId)/acl/$(request.auth.uid));
    }

    match /families/{familyId} {
      allow read: if isMember(familyId);
      // create autorisée à tout utilisateur connecté (création d'un nouveau foyer) ;
      // l'écriture du doc acl associé (ci-dessous) garantit qu'il devient membre dans la même requête batch.
      allow create: if request.auth != null;
      allow update, delete: if isMember(familyId);

      match /acl/{uid} {
        allow read: if request.auth != null;
        // un utilisateur ne peut créer que sa propre adhésion (createFamily / joinFamily).
        allow create: if request.auth != null && request.auth.uid == uid;
        allow update, delete: if isMember(familyId);
      }

      match /members/{memberId} {
        allow read: if isMember(familyId);
        // un utilisateur peut créer son propre profil membre (createFamily / joinFamily,
        // dans le même batch que la création de l'acl, donc isMember() pas encore vrai) ;
        // un membre existant peut ajouter d'autres membres (enfants, etc).
        allow create: if request.auth != null && (memberId == request.auth.uid || isMember(familyId));
        allow update, delete: if isMember(familyId);
      }

      match /{coll}/{docId} {
        allow read, write: if isMember(familyId);
      }

      match /medications/{medId}/movements/{movId} {
        allow read, write: if isMember(familyId);
      }
    }
  }
}
